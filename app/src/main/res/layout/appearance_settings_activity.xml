<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <include
        layout="@layout/settings_toolbar"
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/appearanceModeLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        android:paddingBottom="8dp"
        android:layout_marginStart="24dp"
        android:text="@string/dark_mode"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/settingsToolbar"
        app:layout_constraintStart_toStartOf="parent" />

    <RadioGroup
        android:id="@+id/appearanceModeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/appearanceModeLabel"
        app:layout_constraintStart_toStartOf="parent">

        <RadioButton
            android:id="@+id/appearanceModeSystem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingTop="8dp"
            android:text="@string/system_default"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginEnd="24dp"
            android:paddingBottom="8dp"
            android:text="@string/system_default_hint"
            android:textSize="14sp"
            android:textColor="@color/hint_text" />

        <RadioButton
            android:id="@+id/appearanceModeDark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingTop="8dp"
            android:text="@string/dark"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginEnd="24dp"
            android:paddingBottom="8dp"
            android:text="@string/dark_hint"
            android:textSize="14sp"
            android:textColor="@color/hint_text" />

        <RadioButton
            android:id="@+id/appearanceModeLight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingTop="8dp"
            android:text="@string/light"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginEnd="24dp"
            android:paddingBottom="8dp"
            android:text="@string/light_hint"
            android:textSize="14sp"
            android:textColor="@color/hint_text" />

    </RadioGroup>

</androidx.constraintlayout.widget.ConstraintLayout>
