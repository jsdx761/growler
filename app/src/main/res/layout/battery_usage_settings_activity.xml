<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:screenOrientation="portrait">

    <TextView
        android:id="@+id/foregroundServiceLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:layout_marginStart="24dp"
        android:text="Use foreground service"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Switch
        android:id="@+id/foregroundServiceSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/foregroundServiceHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:text="Keeps the app alive when in the background. Shows a persistent notification."
        android:textSize="12sp"
        android:textColor="@color/hint_text"
        app:layout_constraintTop_toBottomOf="@id/foregroundServiceLabel"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/wakeLockLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:layout_marginStart="24dp"
        android:text="Use wake lock"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/foregroundServiceHint"
        app:layout_constraintStart_toStartOf="parent" />

    <Switch
        android:id="@+id/wakeLockSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/foregroundServiceHint" />

    <TextView
        android:id="@+id/wakeLockHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:text="Prevents the CPU from sleeping. Uses more battery."
        android:textSize="12sp"
        android:textColor="@color/hint_text"
        app:layout_constraintTop_toBottomOf="@id/wakeLockLabel"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
