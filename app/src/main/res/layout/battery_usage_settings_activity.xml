<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <include
        layout="@layout/settings_toolbar"
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/foregroundServiceLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:text="@string/use_foreground_service"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/settingsToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/foregroundServiceSwitch" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/foregroundServiceSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/foregroundServiceLabel"
        app:layout_constraintBottom_toBottomOf="@id/foregroundServiceLabel" />

    <TextView
        android:id="@+id/foregroundServiceHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:text="@string/foreground_service_hint"
        android:textSize="14sp"
        android:textColor="@color/hint_text"
        app:layout_constraintTop_toBottomOf="@id/foregroundServiceLabel"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/wakeLockLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:text="@string/use_wake_lock"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/foregroundServiceHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/wakeLockSwitch" />

    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/wakeLockSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/wakeLockLabel"
        app:layout_constraintBottom_toBottomOf="@id/wakeLockLabel" />

    <TextView
        android:id="@+id/wakeLockHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:text="@string/wake_lock_hint"
        android:textSize="14sp"
        android:textColor="@color/hint_text"
        app:layout_constraintTop_toBottomOf="@id/wakeLockLabel"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
