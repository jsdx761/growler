<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <include
            layout="@layout/settings_toolbar"
            android:id="@+id/settingsToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/voiceBackendLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="20dp"
            android:paddingBottom="8dp"
            android:layout_marginStart="24dp"
            android:text="@string/voice_engine"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/settingsToolbar"
            app:layout_constraintStart_toStartOf="parent" />

        <RadioGroup
            android:id="@+id/voiceBackendGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/voiceBackendLabel"
            app:layout_constraintStart_toStartOf="parent">

            <RadioButton
                android:id="@+id/voiceBackendElevenLabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:paddingTop="8dp"
                android:text="@string/car_voice_elevenlabs"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/voiceBackendElevenLabsHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginEnd="24dp"
                android:paddingBottom="8dp"
                android:text="@string/car_voice_elevenlabs_hint"
                android:textSize="14sp"
                android:textColor="@color/hint_text" />

            <RadioButton
                android:id="@+id/voiceBackendVoxtral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:paddingTop="8dp"
                android:text="@string/car_voice_voxtral"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/voiceBackendVoxtralHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginEnd="24dp"
                android:paddingBottom="8dp"
                android:text="@string/car_voice_voxtral_hint"
                android:textSize="14sp"
                android:textColor="@color/hint_text" />

            <LinearLayout
                android:id="@+id/carVoiceRateSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/carVoiceRateLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp"
                    android:paddingBottom="4dp"
                    android:layout_marginStart="24dp"
                    android:text="@string/voice_speed"
                    android:textSize="16sp" />

                <SeekBar
                    android:id="@+id/carVoiceRateSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:max="3"
                    android:progress="1"
                    android:tickMark="@drawable/seekbar_tick" />

                <TextView
                    android:id="@+id/carVoiceRateValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:paddingBottom="8dp"
                    android:text="1.00x"
                    android:textSize="14sp"
                    android:textColor="@color/hint_text" />

            </LinearLayout>

            <RadioButton
                android:id="@+id/voiceBackendSystem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:paddingTop="8dp"
                android:text="@string/builtin_phone_voice"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/voiceBackendSystemHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginEnd="24dp"
                android:paddingBottom="8dp"
                android:text="@string/builtin_phone_voice_hint"
                android:textSize="14sp"
                android:textColor="@color/hint_text" />

            <RadioButton
                android:id="@+id/voiceBackendTunedLocal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:paddingTop="8dp"
                android:text="@string/dsp_enhanced_voice"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/voiceBackendTunedLocalHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginEnd="24dp"
                android:paddingBottom="8dp"
                android:text="@string/dsp_enhanced_voice_hint"
                android:textSize="14sp"
                android:textColor="@color/hint_text" />

            <LinearLayout
                android:id="@+id/voiceRateSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/voiceSpeedLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="20dp"
                    android:paddingBottom="4dp"
                    android:layout_marginStart="24dp"
                    android:text="@string/speech_rate"
                    android:textSize="16sp" />

                <SeekBar
                    android:id="@+id/voiceSpeedSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:max="200"
                    android:progress="110" />

                <TextView
                    android:id="@+id/voiceSpeedValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="1.10x"
                    android:textSize="14sp"
                    android:textColor="@color/hint_text" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/voicePitchSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/voicePitchLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="20dp"
                    android:paddingBottom="4dp"
                    android:layout_marginStart="24dp"
                    android:text="@string/pitch"
                    android:textSize="16sp" />

                <SeekBar
                    android:id="@+id/voicePitchSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="48dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:max="200"
                    android:progress="90" />

                <TextView
                    android:id="@+id/voicePitchValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="0.90"
                    android:textSize="14sp"
                    android:textColor="@color/hint_text" />

            </LinearLayout>

        </RadioGroup>

        <Button
            android:id="@+id/voiceTestButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:text="@string/test_voice"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/voiceBackendGroup"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
