<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:screenOrientation="portrait">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/voiceBackendLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="20dp"
            android:paddingBottom="8dp"
            android:layout_marginStart="24dp"
            android:text="Voice engine"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <RadioGroup
            android:id="@+id/voiceBackendGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintTop_toBottomOf="@id/voiceBackendLabel"
            app:layout_constraintStart_toStartOf="parent">

            <RadioButton
                android:id="@+id/voiceBackendPreRecordedElevenLabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="Car Voice #1"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginEnd="24dp"
                android:paddingBottom="8dp"
                android:text="Cloned voice, pre-recorded segments. ElevenLabs TTS at 0.82x speed."
                android:textSize="11sp"
                android:textColor="@color/hint_text" />

            <RadioButton
                android:id="@+id/voiceBackendPreRecordedElevenLabs075"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="Car Voice #2"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginEnd="24dp"
                android:paddingBottom="8dp"
                android:text="Cloned voice, pre-recorded segments. ElevenLabs TTS at 0.75x speed."
                android:textSize="11sp"
                android:textColor="@color/hint_text" />

            <RadioButton
                android:id="@+id/voiceBackendPreRecorded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="Car Voice #3"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginEnd="24dp"
                android:paddingBottom="8dp"
                android:text="Cloned voice, pre-recorded segments. Voxtral TTS."
                android:textSize="11sp"
                android:textColor="@color/hint_text" />

            <RadioButton
                android:id="@+id/voiceBackendSystem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="Built-in Phone Voice"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginEnd="24dp"
                android:paddingBottom="8dp"
                android:text="Uses the phone's default TTS engine. Adjustable speed and pitch."
                android:textSize="11sp"
                android:textColor="@color/hint_text" />

            <RadioButton
                android:id="@+id/voiceBackendTunedLocal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="DSP-Enhanced Voice"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginEnd="24dp"
                android:paddingBottom="8dp"
                android:text="Phone's default TTS processed through optimized DSP audio filters."
                android:textSize="11sp"
                android:textColor="@color/hint_text" />

        </RadioGroup>

        <LinearLayout
            android:id="@+id/voiceSlidersSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/voiceBackendGroup"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/voiceSpeedLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:paddingBottom="4dp"
                android:layout_marginStart="24dp"
                android:text="Speech rate"
                android:textSize="16sp" />

            <SeekBar
                android:id="@+id/voiceSpeedSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:max="200"
                android:progress="110" />

            <TextView
                android:id="@+id/voiceSpeedValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="1.10x"
                android:textSize="14sp"
                android:textColor="@color/hint_text" />

            <TextView
                android:id="@+id/voicePitchLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:paddingBottom="4dp"
                android:layout_marginStart="24dp"
                android:text="Pitch"
                android:textSize="16sp" />

            <SeekBar
                android:id="@+id/voicePitchSeekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:max="200"
                android:progress="90" />

            <TextView
                android:id="@+id/voicePitchValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="0.90"
                android:textSize="14sp"
                android:textColor="@color/hint_text" />

        </LinearLayout>

        <Button
            android:id="@+id/voiceTestButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:text="Test Voice"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/voiceSlidersSection"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
