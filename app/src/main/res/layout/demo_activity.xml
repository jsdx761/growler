<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:screenOrientation="portrait">

    <TextView
        android:id="@+id/demoDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:text="Run a demo with simulated alerts. Tap a button to send sample alerts, then navigate to the main screen to hear the announcements."
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/demoRadarButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="8dp"
        android:text="Radar Alerts Demo"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/demoDescription"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/demoCrowdSourcedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="8dp"
        android:text="Crowd-sourced Alerts Demo"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/demoRadarButton"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/demoAircraftButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="8dp"
        android:text="Aircraft Alerts Demo"
        android:textAllCaps="false"
        app:layout_constraintTop_toBottomOf="@id/demoCrowdSourcedButton"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
